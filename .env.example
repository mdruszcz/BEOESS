# ─────────────────────────────────────────────────────────────
# study-library — environment variables
# Copy this file to ".env" and fill in real values.
# NEVER commit the real .env file.
# ─────────────────────────────────────────────────────────────

# --- Database (Neon, Supabase, or any Postgres) ---------------
# Neon free tier: https://neon.tech  → copy the pooled connection string.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- Auth.js (NextAuth v5) ------------------------------------
# Generate a secret with:  npx auth secret    (or: openssl rand -base64 32)
AUTH_SECRET="replace-with-a-long-random-string"
# Public URL of the deployed site. Locally: http://localhost:3000
AUTH_URL="http://localhost:3000"

# --- Signup restriction ---------------------------------------
# Only emails ending in this domain may register.
ALLOWED_EMAIL_DOMAIN="minfin.fed.be"

# --- Cloudflare R2 (S3-compatible object storage) -------------
# Dashboard → R2 → Manage API Tokens → create an Access Key.
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="study-library"
# The S3 API endpoint: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT="https://your-cloudflare-account-id.r2.cloudflarestorage.com"
# Public read host for the bucket (R2 "Public Development URL" or a custom domain),
# WITHOUT the https:// prefix. Example: pub-abc123.r2.dev
NEXT_PUBLIC_R2_PUBLIC_HOST="pub-xxxxxxxx.r2.dev"

# --- First admin (used by the seed script) --------------------
SEED_ADMIN_EMAIL="prenom.nom@minfin.fed.be"
SEED_ADMIN_PASSWORD="change-me-on-first-login"
SEED_ADMIN_NAME="Administrateur"
